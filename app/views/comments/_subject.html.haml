#comments.CommentFeed
  - if policy(Comment).new?
    .CommentFeed-newComment.mb-4
      = render partial: 'comments/form', locals: { subject: subject }
  .CommentFeed-comments
    - @parent = subject
    - comments = Comment.for_subject(subject).includes(:actual_author).for_feed(current_user)
    = render comments
  - unless comments.last_page?
    .u-textRight
      = link_to('older comments', [ subject, :comments ])
